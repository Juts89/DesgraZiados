    "RuleCategories": [
        {
            "CategoryName": "General",
            "Rules": [
                {
                    "RuleParagraph": "1.1.",
                    "RuleText": "Los insultos, la discriminación y cualquier mensaje o texto extremista o racista están prohibidos."
                },
                {
                    "RuleParagraph": "1.2.",
                    "RuleText": "Nos reservamos el derecho de expulsar del servidor a quienes difundan ideas extremistas o racistas, o alteren claramente la convivencia."
                },
                {
                    "RuleParagraph": "1.3.",
                    "RuleText": "Las decisiones del equipo, tanto soporte como administración, deben respetarse sin discusión."
                },
                {
                    "RuleParagraph": "1.4.",
                    "RuleText": "Las provocaciones y el comportamiento tóxico no se tolerarán y serán sancionados. Sé respetuoso con otros jugadores y con el equipo, tanto por chat como por voz."
                },
                {
                    "RuleParagraph": "1.5.",
                    "RuleText": "El uso de programas externos, scripts o trampas no está permitido y será sancionado con expulsión permanente."
                }
            ]
        }
    ],
